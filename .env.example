# Example .env (for sharing with teammates)
# Copy this to .env and fill in real values. Do NOT commit real secrets.

# Optional: OpenAI key (example)
# OPENAI_API_KEY="your_openai_api_key_here"

# News API
NEWS_API_KEY=your_news_api_key_here

# Groq (LLM provider)
GROQ_API_KEY=your_groq_api_key_here

# Search (Serper)
SERPER_API_KEY=your_serper_api_key_here

# Vector DB (optional)
PINECONE_API_KEY=your_pinecone_api_key_here

# App config
MODEL_PROVIDER=groq   # openai / groq / together
GROQ_MODEL=llama-3.3-70b-versatile

# Together API (if using Together)
TOGETHER_API_KEY=your_together_api_key_here
TOGETHER_MODEL=optional_together_model_name
TOGETHER_API_URL=https://api.together.ai

# Supabase (replace with your project URL & anon/public key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_STORAGE_BUCKET=pdfs

# Notes:
# - Replace placeholder values above with real keys before running.
# - Keep the real `.env` private and out of version control.
